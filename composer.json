{
  "name": "inwebo/csv",
  "description": "This PHP class, provides a simple yet powerful way to read and process CSV files. Built as an extension of PHP's SplFileObject, it offers advanced features like column name mapping, data filtering, and sanitization to streamline your CSV processing tasks.",
  "keywords": ["csv-parser", "csv-import", "data-processing", "etl", "file-reader", "spreadsheet", "csv", "reader", "php", "filter", "spl", "sanitize"],
  "homepage": "https://github.com/inwebo/csv-reader",
  "authors": [
    {
      "name": "Inwebo Veritas",
      "email": "github@inwebo.net",
      "homepage": "https://www.inwebo.net",
      "role": "Developer"
    }
  ],
  "type": "library",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "friendsofphp/php-cs-fixer": "^3.72",
    "phpstan/phpstan": "^2.1",
    "phpmd/phpmd": "^2.15",
    "phpbench/phpbench": "^1.7"
  },
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Inwebo\\Csv\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Inwebo\\Csv\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "php-cs-fixer": "vendor/bin/php-cs-fixer --allow-risky=yes fix",
    "phpunit": "XDEBUG_MODE=coverage vendor/bin/phpunit --testdox --display-all-issues",
    "phpstan": "vendor/bin/phpstan analyse src -c phpstan.neon",
    "phpmd": "vendor/bin/phpmd ./src html ./phpmd.rulesets.xml --reportfile phpmd-report/index.html",
    "phpbench": "XDEBUG_MODE=off vendor/bin/phpbench run benchmarks/ --report=aggregate",
    "phpbench-html": "XDEBUG_MODE=off vendor/bin/phpbench run benchmarks/ --report=aggregate --output=html",
    "phpbench-compare": "XDEBUG_MODE=off vendor/bin/phpbench run benchmarks/ --report=compare --ref=v1"
  },
  "config": {
    "process-timeout": 0
  },
  "minimum-stability": "stable"
}
